{
  "name": "@context-stash/mcp-server",
  "version": "0.1.0",
  "description": "Local MCP server that exposes Context Stash conversations to MCP-aware agents (Claude Code, Cursor, Zed).",
  "type": "module",
  "bin": {
    "context-stash-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binary": "bun build src/index.ts --compile --outfile=dist/context-stash-mcp",
    "build:mac-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=dist/context-stash-mcp-darwin-arm64",
    "build:mac-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=dist/context-stash-mcp-darwin-x64",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile=dist/context-stash-mcp-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile=dist/context-stash-mcp-linux-arm64",
    "build:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile=dist/context-stash-mcp-windows-x64.exe",
    "build:all-platforms": "npm run build:mac-arm64 && npm run build:mac-x64 && npm run build:linux-x64 && npm run build:linux-arm64 && npm run build:windows-x64",
    "dev": "tsc -p tsconfig.json -w",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "files": [
    "dist"
  ]
}
